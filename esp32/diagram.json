{
  "version": 1,
  "author": "esp32-aviario",
  "editor": "wokwi",
  "parts": [
    {
      "type": "wokwi-esp32-devkit-v1",
      "id": "esp",
      "top": 0,
      "left": 0,
      "attrs": {}
    },
    {
      "type": "wokwi-dht22",
      "id": "dht1",
      "top": -60,
      "left": 220,
      "attrs": { "temperature": "28", "humidity": "55" }
    },
    {
      "type": "wokwi-resistor",
      "id": "r1",
      "top": -10,
      "left": 190,
      "rotate": 90,
      "attrs": { "value": "10000" }
    },
    {
      "type": "wokwi-hx711",
      "id": "hx1",
      "top": 120,
      "left": 220,
      "attrs": { "type": "5kg" }
    }
  ],
  "connections": [
    ["esp:TX0", "$serialMonitor:RX", "", []],
    ["esp:RX0", "$serialMonitor:TX", "", []],

    ["esp:3V3", "dht1:VCC", "red", ["v-10", "h0"]],
    ["esp:GND.1", "dht1:GND", "black", ["v-5", "h0"]],
    ["esp:D4", "dht1:SDA", "green", ["h0"]],
    ["r1:1", "dht1:VCC", "red", ["v0"]],
    ["r1:2", "dht1:SDA", "green", ["v0"]],

    ["esp:3V3", "hx1:VCC", "red", ["v0", "h0"]],
    ["esp:GND.2", "hx1:GND", "black", ["v0", "h0"]],
    ["esp:D18", "hx1:DT", "green", ["h0"]],
    ["esp:D19", "hx1:SCK", "green", ["h0"]]
  ]
}
